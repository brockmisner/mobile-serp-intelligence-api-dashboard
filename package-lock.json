{
  "name": "mobile-serp-intelligence-api-dashboard",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "mobile-serp-intelligence-api-dashboard",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20.0.0"
      }
    },
    "apps/api": {
      "name": "@mobile-serp/api",
      "version": "0.1.0"
    },
    "apps/dashboard": {
      "name": "@mobile-serp/dashboard",
      "version": "0.1.0"
    },
    "node_modules/@mobile-serp/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@mobile-serp/dashboard": {
      "resolved": "apps/dashboard",
      "link": true
    },
    "node_modules/@mobile-serp/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@mobile-serp/shared",
      "version": "0.1.0"
    }
  }
}
