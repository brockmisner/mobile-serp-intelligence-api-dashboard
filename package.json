{
  "name": "mobile-serp-intelligence-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "build": "npm run lint",
    "ci:verify": "npm run lint && npm run test && npm run build",
    "lint": "node --check src/*.js src/middleware/*.js src/routes/*.js tests/*.js apps/api/src/*.js apps/api/src/controllers/*.js apps/api/src/routes/*.js apps/api/src/routes/v1/*.js packages/shared/src/*.js",
    "test": "vitest run tests/auth.integration.test.js tests/app.integration.test.js",
    "test:all": "vitest run",
    "test:watch": "vitest tests/auth.integration.test.js tests/app.integration.test.js",
    "deploy": "node scripts/deploy.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "test:smoke:deployment": "node tests/deployment.smoke.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "supertest": "^7.1.1",
    "vitest": "^2.1.1"
  }
}
